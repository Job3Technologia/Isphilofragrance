[
  {
    "name": "Theme settings",
    "theme_name": "Isphilo Fragrance",
    "theme_author": "Isphilo AI Assistant",
    "theme_version": "1.2.0"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Brand Colors"
      },
      {
        "type": "color",
        "id": "primary_red",
        "label": "Primary Red",
        "default": "#D42E2E"
      },
      {
        "type": "color",
        "id": "primary_red_dark",
        "label": "Primary Red Dark",
        "default": "#A11F1F"
      },
      {
        "type": "color",
        "id": "gold",
        "label": "Gold",
        "default": "#C5A059"
      },
      {
        "type": "color",
        "id": "gold_light",
        "label": "Gold Light",
        "default": "#E0C080"
      },
      {
        "type": "header",
        "content": "Neutral Colors"
      },
      {
        "type": "color",
        "id": "pure_black",
        "label": "Pure Black",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "pure_white",
        "label": "Pure White",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "off_white",
        "label": "Off White",
        "default": "#F9F9F9"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Font",
        "default": "playfair_display_n4"
      },
      {
        "type": "range",
        "id": "type_header_base_size",
        "min": 16,
        "max": 50,
        "step": 1,
        "unit": "px",
        "label": "Base Size",
        "default": 32
      },
      {
        "type": "header",
        "content": "Body Text"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Font",
        "default": "montserrat_n4"
      },
      {
        "type": "range",
        "id": "type_body_base_size",
        "min": 12,
        "max": 24,
        "step": 1,
        "unit": "px",
        "label": "Base Size",
        "default": 16
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social Links"
      },
      {
        "type": "url",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_instagram_link",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_tiktok_link",
        "label": "TikTok"
      },
      {
        "type": "url",
        "id": "social_twitter_link",
        "label": "Twitter"
      },
      {
        "type": "url",
        "id": "social_pinterest_link",
        "label": "Pinterest"
      },
      {
        "type": "text",
        "id": "social_whatsapp_number",
        "label": "WhatsApp Number (without +)",
        "default": "27766834283"
      },
      {
        "type": "header",
        "content": "Sharing Options"
      },
      {
        "type": "checkbox",
        "id": "share_facebook",
        "label": "Enable Facebook Sharing",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "share_twitter",
        "label": "Enable Twitter Sharing",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "share_pinterest",
        "label": "Enable Pinterest Sharing",
        "default": true
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon Image",
        "info": "Will be scaled to 32x32px"
      }
    ]
  }
