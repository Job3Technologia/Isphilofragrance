{% comment %}
  ISPHILO FRAGRANCE - 404 Page Template
{% endcomment %}

<section class="section error-section">
    <div class="container text-center">
        <div class="error-content reveal">
            <p class="section-subtitle">Error 404</p>
            <h1 class="error-title">Scent Not Found</h1>
            <div class="section-divider"></div>
            <p class="error-text">The page you are looking for has evaporated or moved to another collection.</p>
            
            <div class="btn-group" style="justify-content: center; margin-top: 40px;">
                <a href="{{ routes.root_url }}" class="btn">Return Home</a>
                <a href="{{ routes.all_products_collection_url }}" class="btn btn-outline">Explore Shop</a>
            </div>
        </div>
    </div>
</section>

<style>
    .error-section { min-height: 70vh; display: flex; align-items: center; justify-content: center; background: var(--off-white); }
    .error-title { font-size: clamp(2.5rem, 8vw, 5rem); margin-bottom: 20px; }
    .error-text { font-size: 1.2rem; opacity: 0.7; max-width: 500px; margin: 0 auto; }
</style>
