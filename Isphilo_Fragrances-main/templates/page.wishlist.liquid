{% comment %}
  ISPHILO FRAGRANCE - Wishlist Page Template
  Uses LocalStorage to display saved items
{% endcomment %}

<section class="section wishlist-header">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-subtitle">Your Favorites</p>
            <h1 class="section-title">My Wishlist</h1>
            <div class="section-divider"></div>
            <p class="wishlist-intro">A curated collection of your favorite Isphilo scents, waiting for you to make them your own.</p>
        </div>
    </div>
</section>

<section class="section wishlist-section">
    <div class="container">
        <div id="wishlistItems" class="product-grid reveal">
            {% comment %} Wishlist items will be injected here by JS {% endcomment %}
            <div class="loading-wishlist text-center">
                <i class="fas fa-spinner fa-spin" style="font-size: 30px; color: var(--primary-red);"></i>
                <p>Loading your favorites...</p>
            </div>
        </div>

        <div id="emptyWishlist" class="empty-wishlist text-center" style="display: none;">
            <i class="far fa-heart" style="font-size: 60px; color: var(--gray-light); margin-bottom: 30px;"></i>
            <h2>Your wishlist is currently empty</h2>
            <p>Save your favorite fragrances here to view them later.</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn" style="margin-top: 30px;">Explore Collection</a>
        </div>
    </div>
</section>

<style>
    .wishlist-header { background: var(--off-white); padding: 120px 0 60px; text-align: center; }
    .wishlist-intro { max-width: 600px; margin: 20px auto 0; opacity: 0.7; font-size: 1.1rem; line-height: 1.8; }
    
    .wishlist-section { padding-bottom: 100px; }
    .empty-wishlist { padding: 100px 0; }
    
    .loading-wishlist { padding: 50px 0; }
    .loading-wishlist i { margin-bottom: 15px; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', async function() {
        const wishlistGrid = document.getElementById('wishlistItems');
        const emptyWishlist = document.getElementById('emptyWishlist');
        const wishlist = JSON.parse(localStorage.getItem('wishlist') || '[]');

        if (wishlist.length === 0) {
            wishlistGrid.style.display = 'none';
            emptyWishlist.style.display = 'block';
            return;
        }

        try {
            // Fetch product details for each handle in wishlist
            const productCards = await Promise.all(wishlist.map(async (handle) => {
                const response = await fetch(`/products/${handle}?view=card`);
                if (response.ok) {
                    return await response.text();
                }
                return null;
            }));

            const validCards = productCards.filter(card => card !== null);
            
            if (validCards.length > 0) {
                wishlistGrid.innerHTML = validCards.join('');
                // Re-trigger reveal animations
                if (typeof reveal === 'function') reveal();
            } else {
                wishlistGrid.style.display = 'none';
                emptyWishlist.style.display = 'block';
            }
        } catch (error) {
            console.error('Error loading wishlist:', error);
            wishlistGrid.style.display = 'none';
            emptyWishlist.style.display = 'block';
        }
    });
</script>
