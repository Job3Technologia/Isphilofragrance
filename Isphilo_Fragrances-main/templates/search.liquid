{% comment %}
  ISPHILO FRAGRANCE - Search Results Template
{% endcomment %}

<section class="section search-header">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-subtitle">{{ 'general.search.title' | t }}</p>
            <h1 class="section-title">
                {% if search.performed %}
                    {{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
                {% else %}
                    {{ 'general.search.title' | t }}
                {% endif %}
            </h1>
            <div class="section-divider"></div>
        </div>

        <div class="search-form-container reveal">
            <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
                <input type="text" name="q" value="{{ search.terms | escape }}" placeholder="Search for your signature scent...">
                <button type="submit" class="btn"><i class="fas fa-search"></i></button>
            </form>
        </div>
    </div>
</section>

<section class="section search-results-section">
    <div class="container">
        {% if search.performed %}
            {% if search.results_count > 0 %}
                <div class="product-grid">
                    {% for item in search.results %}
                        {% if item.object_type == 'product' %}
                            {% render 'product-card', product: item %}
                        {% endif %}
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center no-results reveal">
                    <i class="fas fa-search-minus" style="font-size: 50px; color: var(--gray-light); margin-bottom: 20px;"></i>
                    <p>We couldn't find any results for "{{ search.terms }}". Try another scent?</p>
                    <a href="{{ routes.all_products_collection_url }}" class="btn btn-outline" style="margin-top: 20px;">Browse Collection</a>
                </div>
            {% endif %}
        {% endif %}
    </div>
</section>

<style>
    .search-header { background: var(--off-white); padding: 100px 0 60px; }
    .search-form-container { max-width: 700px; margin: 40px auto 0; }
    .search-form { display: flex; gap: 10px; }
    .search-form input { flex: 1; padding: 15px 25px; border: 1px solid var(--gray-light); border-radius: 50px; font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; }
    .search-form .btn { border-radius: 50px; width: 60px; height: 60px; padding: 0; display: flex; align-items: center; justify-content: center; }
    .no-results { padding: 80px 0; }
</style>
