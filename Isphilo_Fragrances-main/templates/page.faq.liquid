{% comment %}
  ISPHILO FRAGRANCE - FAQ Page Template
{% endcomment %}

<section class="section faq-header">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-subtitle">Common Questions</p>
            <h1 class="section-title">Fragrance FAQ</h1>
            <div class="section-divider"></div>
        </div>
    </div>
</section>

<section class="section faq-section">
    <div class="container">
        <div class="faq-grid reveal">
            {% comment %} This can be converted to blocks in a section if preferred, but for now we'll use a clean template structure {% endcomment %}
            <div class="faq-category">
                <h2>Ordering & Shipping</h2>
                
                <div class="faq-item">
                    <div class="faq-question">How long does shipping take? <i class="fas fa-plus"></i></div>
                    <div class="faq-answer">
                        <p>For South African orders, delivery typically takes 2-5 business days. International shipping varies by destination but usually arrives within 7-14 business days via our premium courier partners (Aramex/DHL).</p>
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">Which delivery services do you use? <i class="fas fa-plus"></i></div>
                    <div class="faq-answer">
                        <p>We partner with Pexi (for store pickups), Aramex (door-to-door), and PostNet to ensure your exquisite scents reach you safely and efficiently.</p>
                    </div>
                </div>
            </div>

            <div class="faq-category">
                <h2>Our Fragrances</h2>
                
                <div class="faq-item">
                    <div class="faq-question">Are your fragrances long-lasting? <i class="fas fa-plus"></i></div>
                    <div class="faq-answer">
                        <p>Yes! Isphilo Fragrances are crafted with high concentrations of premium essential oils, designed to linger for 8-12 hours depending on the specific blend and skin type.</p>
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">Where are Isphilo Fragrances made? <i class="fas fa-plus"></i></div>
                    <div class="faq-answer">
                        <p>Every bottle is meticulously blended and hand-poured in our boutique studio in Berea, Durban, South Africa.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .faq-header { background: var(--off-white); padding: 120px 0 60px; text-align: center; }
    .faq-grid { max-width: 800px; margin: 0 auto; }
    
    .faq-category { margin-bottom: 60px; }
    .faq-category h2 { font-size: 14px; color: var(--primary-red); margin-bottom: 30px; letter-spacing: 2px; }
    
    .faq-item { border-bottom: 1px solid var(--gray-light); margin-bottom: 10px; }
    .faq-question { padding: 25px 0; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 15px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; transition: all 0.3s ease; }
    .faq-question i { font-size: 12px; transition: transform 0.4s ease; color: var(--gold); }
    .faq-question:hover { color: var(--primary-red); }
    
    .faq-item.active .faq-question { color: var(--primary-red); }
    .faq-item.active .faq-question i { transform: rotate(45deg); }
    
    .faq-answer { max-height: 0; overflow: hidden; transition: all 0.5s cubic-bezier(0, 1, 0, 1); }
    .faq-answer p { padding-bottom: 25px; opacity: 0.7; line-height: 1.8; }
    .faq-item.active .faq-answer { max-height: 1000px; transition: all 0.5s cubic-bezier(1, 0, 1, 0); }
</style>

<script>
    document.querySelectorAll('.faq-question').forEach(q => {
        q.addEventListener('click', () => {
            const item = q.parentElement;
            item.classList.toggle('active');
        });
    });
</script>
