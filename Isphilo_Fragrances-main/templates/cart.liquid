{% comment %}
  ISPHILO FRAGRANCE - Cart Page Template
{% endcomment %}

<section class="section cart-header">
    <div class="container">
        <div class="section-header reveal">
            <p class="section-subtitle">Your Selection</p>
            <h1 class="section-title">Shopping Cart</h1>
            <div class="section-divider"></div>
        </div>
    </div>
</section>

<section class="section cart-section">
    <div class="container">
        {% if cart.item_count > 0 %}
            <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-form">
                <div class="cart-grid">
                    <div class="cart-items-container reveal-left">
                        <table class="cart-table">
                            <thead>
                                <tr>
                                    <th colspan="2">Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in cart.items %}
                                    <tr class="cart-item" data-id="{{ item.id }}">
                                        <td class="cart-item-image">
                                            <a href="{{ item.url }}">
                                                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title }}" loading="lazy">
                                            </a>
                                        </td>
                                        <td class="cart-item-details">
                                            <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
                                            {% unless item.product.has_only_default_variant %}
                                                <p class="item-variant">{{ item.variant.title }}</p>
                                            {% endunless %}
                                            <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0" class="remove-btn">Remove</a>
                                        </td>
                                        <td class="cart-item-price">
                                            {{ item.price | money }}
                                        </td>
                                        <td class="cart-item-qty">
                                            <div class="qty-controls">
                                                <button type="button" onclick="changeCartQty('{{ forloop.index }}', -1)"><i class="fas fa-minus"></i></button>
                                                <input type="number" name="updates[]" id="updates_{{ item.id }}" value="{{ item.quantity }}" min="0">
                                                <button type="button" onclick="changeCartQty('{{ forloop.index }}', 1)"><i class="fas fa-plus"></i></button>
                                            </div>
                                        </td>
                                        <td class="cart-item-total">
                                            {{ item.final_line_price | money }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <div class="cart-summary-container reveal-right">
                        <div class="cart-summary-card">
                            <h3>Order Summary</h3>
                            <div class="summary-row">
                                <span>Subtotal</span>
                                <span class="cart-subtotal">{{ cart.total_price | money }}</span>
                            </div>
                            <div class="summary-row">
                                <span>Shipping</span>
                                <span>Calculated at checkout</span>
                            </div>
                            <div class="summary-divider"></div>
                            <div class="summary-row total">
                                <span>Total</span>
                                <span class="cart-total">{{ cart.total_price | money }}</span>
                            </div>
                            
                            <p class="tax-note">Taxes and shipping calculated at checkout</p>
                            
                            <button type="submit" name="checkout" class="btn btn-checkout" style="width: 100%;">Proceed to Checkout <i class="fas fa-lock" style="margin-left: 10px;"></i></button>
                            
                            <div class="text-center" style="margin-top: 20px;">
                                <a href="{{ routes.all_products_collection_url }}" class="link-btn">Continue Shopping</a>
                            </div>
                            
                            <div class="payment-methods" style="margin-top: 30px; opacity: 0.5; display: flex; justify-content: center; gap: 15px; font-size: 24px;">
                                <i class="fab fa-cc-visa"></i>
                                <i class="fab fa-cc-mastercard"></i>
                                <i class="fab fa-cc-apple-pay"></i>
                                <i class="fas fa-credit-card"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        {% else %}
            <div class="empty-cart reveal text-center">
                <i class="fas fa-shopping-bag" style="font-size: 60px; color: var(--gray-light); margin-bottom: 30px;"></i>
                <h2>Your cart is currently empty</h2>
                <p>Add some exquisite scents to your collection!</p>
                <a href="{{ routes.all_products_collection_url }}" class="btn" style="margin-top: 30px;">Start Shopping</a>
            </div>
        {% endif %}
    </div>
</section>

<style>
    .cart-header { background: var(--off-white); padding: 120px 0 60px; }
    .cart-grid { display: grid; grid-template-columns: 1fr 350px; gap: 60px; margin-top: 60px; align-items: start; }
    
    .cart-table { width: 100%; border-collapse: collapse; }
    .cart-table th { text-align: left; padding: 20px 0; border-bottom: 2px solid var(--gray-light); font-family: 'Montserrat', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 2px; }
    .cart-item td { padding: 30px 0; border-bottom: 1px solid var(--gray-light); }
    
    .cart-item-image img { width: 100px; border-radius: 12px; }
    .cart-item-details h3 { font-size: 1.2rem; margin-bottom: 5px; }
    .item-variant { font-size: 13px; opacity: 0.6; margin-bottom: 10px; }
    .remove-btn { font-size: 11px; font-weight: 700; color: var(--primary-red); text-transform: uppercase; text-decoration: none; }
    
    .qty-controls { display: flex; align-items: center; border: 1px solid var(--gray-light); border-radius: 50px; width: fit-content; }
    .qty-controls button { background: none; border: none; padding: 10px 15px; cursor: pointer; color: var(--gray-dark); }
    .qty-controls input { border: none; width: 40px; text-align: center; font-family: 'Montserrat', sans-serif; font-weight: 700; background: transparent; }
    
    .cart-summary-card { background: var(--pure-black); color: white; padding: 40px; border-radius: 20px; position: sticky; top: 120px; }
    .cart-summary-card h3 { font-size: 1.4rem; margin-bottom: 30px; font-family: 'Playfair Display', serif; }
    .summary-row { display: flex; justify-content: space-between; margin-bottom: 15px; font-size: 14px; opacity: 0.8; }
    .summary-row.total { font-size: 1.2rem; font-weight: 700; opacity: 1; color: var(--gold); }
    .summary-divider { height: 1px; background: rgba(255,255,255,0.1); margin: 20px 0; }
    .tax-note { font-size: 11px; opacity: 0.5; margin-bottom: 30px; text-align: center; }
    
    .empty-cart { padding: 100px 0; }
    
    @media (max-width: 992px) {
        .cart-grid { grid-template-columns: 1fr; gap: 40px; }
        .cart-table thead { display: none; }
        .cart-item { display: grid; grid-template-columns: 100px 1fr; gap: 20px; }
        .cart-item td { border: none; padding: 0; }
        .cart-item-image { grid-row: span 3; }
        .cart-item-qty, .cart-item-total { display: none; }
    }
</style>

<script>
    function changeCartQty(line, amt) {
        const input = document.querySelectorAll('.cart-form input[type="number"]')[line - 1];
        let val = parseInt(input.value) + amt;
        if (val < 0) val = 0;
        input.value = val;
        // Submit form to update cart
        document.querySelector('.cart-form').submit();
    }
</script>
