{% comment %}
  ISPHILO FRAGRANCE - Register Template
{% endcomment %}

<section class="section auth-section">
    <div class="container">
        <div class="auth-grid">
            <div class="auth-image reveal-left">
                <img src="{{ 'Images/IMG-20260316-WA0035.jpg' | asset_url }}" alt="Register Background" loading="lazy">
                <div class="auth-overlay">
                    <h2>Join the Inner Circle</h2>
                    <p>Experience the ultimate fragrance collection and enjoy VIP access to new releases.</p>
                </div>
            </div>
            
            <div class="auth-form-container reveal-right">
                <div class="auth-header">
                    <p class="section-subtitle">Sign Up</p>
                    <h1 class="auth-title">Create Account</h1>
                    <div class="section-divider" style="margin-left: 0;"></div>
                </div>

                {% form 'create_customer', class: 'auth-form' %}
                    {{ form.errors | default_errors }}

                    <div class="form-group">
                        <label for="FirstName">First Name</label>
                        <input type="text" name="customer[first_name]" id="FirstName" placeholder="First Name" required>
                    </div>

                    <div class="form-group">
                        <label for="LastName">Last Name</label>
                        <input type="text" name="customer[last_name]" id="LastName" placeholder="Last Name" required>
                    </div>

                    <div class="form-group">
                        <label for="Email">Email Address</label>
                        <input type="email" name="customer[email]" id="Email" placeholder="Email Address" required>
                    </div>

                    <div class="form-group">
                        <label for="CreatePassword">Password</label>
                        <input type="password" name="customer[password]" id="CreatePassword" placeholder="Password" required>
                    </div>

                    <button type="submit" class="btn" style="width: 100%;">Sign Up <i class="fas fa-user-plus" style="margin-left: 10px;"></i></button>

                    <div class="auth-footer">
                        <p>Already have an account? <a href="{{ routes.account_login_url }}">Sign in here</a></p>
                    </div>
                {% endform %}
            </div>
        </div>
    </div>
</section>

<style>
    .auth-section { min-height: 100vh; display: flex; align-items: center; padding: 120px 0 60px; }
    .auth-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .auth-image { position: relative; height: 600px; border-radius: 20px; overflow: hidden; }
    .auth-image img { width: 100%; height: 100%; object-fit: cover; }
    .auth-overlay { position: absolute; bottom: 0; left: 0; width: 100%; padding: 40px; background: linear-gradient(transparent, rgba(0,0,0,0.8)); color: white; }
    .auth-overlay h2 { font-size: 32px; margin-bottom: 10px; }
    .auth-overlay p { opacity: 0.8; font-size: 14px; }
    
    .auth-title { font-size: 2.5rem; margin-bottom: 20px; }
    .auth-form { margin-top: 40px; }
    .form-group { margin-bottom: 25px; }
    .form-group label { display: block; font-family: 'Montserrat', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; margin-bottom: 10px; }
    .form-group input { width: 100%; padding: 15px; border: 1px solid var(--gray-light); border-radius: 12px; font-family: 'Cormorant Garamond', serif; font-size: 1rem; }
    
    .auth-footer { margin-top: 30px; text-align: center; font-size: 14px; }
    .auth-footer a { color: var(--primary-red); font-weight: 700; text-decoration: none; }
    
    @media (max-width: 992px) {
        .auth-grid { grid-template-columns: 1fr; gap: 50px; }
        .auth-image { height: 300px; }
    }
</style>
