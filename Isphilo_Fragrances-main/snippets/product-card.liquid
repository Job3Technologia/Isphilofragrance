{% comment %}
  ISPHILO FRAGRANCE - Product Card Snippet
{% endcomment %}

<div class="product-card reveal" onclick="window.location.href='{{ product.url }}'">
    <div class="product-image">
        <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
        
        {%- if product.compare_at_price > product.price -%}
            <div class="product-badge">Sale</div>
        {%- elsif product.tags contains 'New' -%}
            <div class="product-badge">New</div>
        {%- elsif product.tags contains 'Popular' -%}
            <div class="product-badge">Popular</div>
        {%- endif -%}

        {%- unless product.available -%}
            <div class="product-badge sold-out-badge">Sold Out</div>
        {%- endunless -%}

        <div class="product-overlay">
            <div class="product-actions">
                <form action="/cart/add" method="post" enctype="multipart/form-data" class="add-to-cart-form">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <button type="submit" aria-label="Add to Cart" {% unless product.available %}disabled{% endunless %}>
                        <i class="fas fa-shopping-bag" aria-hidden="true"></i>
                    </button>
                </form>
                <button onclick="event.stopPropagation(); window.location.href='{{ product.url }}'" aria-label="View Details">
                    <i class="fas fa-eye" aria-hidden="true"></i>
                </button>
                <button type="button" class="wishlist-toggle-btn" data-handle="{{ product.handle }}" onclick="event.stopPropagation(); toggleWishlist('{{ product.handle }}', this)" aria-label="Add to Wishlist">
                    <i class="far fa-heart" aria-hidden="true"></i>
                </button>
            </div>
        </div>
    </div>
    <div class="product-info">
        <p class="product-category">{{ product.collections.first.title }}</p>
        <h5 class="product-name">{{ product.title }}</h5>
        <p class="product-price">
            <span class="current-price">{{ product.price | money }}</span>
            {%- if product.compare_at_price > product.price -%}
                <span class="old-price">{{ product.compare_at_price | money }}</span>
            {%- endif -%}
        </p>
        <form action="/cart/add" method="post" enctype="multipart/form-data">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <button type="submit" class="btn-add-to-cart {% unless product.available %}sold-out{% endunless %}" 
                    {% unless product.available %}disabled{% endunless %}>
                {% if product.available %}Add to cart{% else %}Out of Stock{% endif %}
            </button>
        </form>
    </div>
</div>
