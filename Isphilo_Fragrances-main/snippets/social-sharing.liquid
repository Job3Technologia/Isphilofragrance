{% comment %}
  ISPHILO FRAGRANCE - Social Sharing Snippet
{% endcomment %}

<div class="social-sharing">
  <span class="share-title">Share this scent:</span>
  <div class="share-links">
    <a target="_blank" href="//www.facebook.com/sharer.php?u={{ shop.url | append: share_permalink }}" class="share-link facebook" title="Share on Facebook">
      <i class="fab fa-facebook-f"></i>
    </a>
    <a target="_blank" href="//twitter.com/share?text={{ share_title | url_param_escape }}&amp;url={{ shop.url | append: share_permalink }}" class="share-link twitter" title="Share on Twitter">
      <i class="fab fa-twitter"></i>
    </a>
    <a target="_blank" href="//pinterest.com/pin/create/button/?url={{ shop.url | append: share_permalink }}&amp;media={{ share_image | image_url: width: 1024, height: 1024 }}&amp;description={{ share_title | url_param_escape }}" class="share-link pinterest" title="Pin on Pinterest">
      <i class="fab fa-pinterest-p"></i>
    </a>
    <a target="_blank" href="https://wa.me/?text={{ share_title | url_param_escape }}%20{{ shop.url | append: share_permalink }}" class="share-link whatsapp" title="Share on WhatsApp">
      <i class="fab fa-whatsapp"></i>
    </a>
  </div>
</div>

<style>
  .social-sharing {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--gray-light);
  }
  .share-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 700;
    opacity: 0.6;
  }
  .share-links {
    display: flex;
    gap: 15px;
  }
  .share-link {
    color: var(--gray-dark);
    font-size: 16px;
    transition: all 0.3s ease;
  }
  .share-link:hover {
    color: var(--primary-red);
    transform: translateY(-3px);
  }
</style>
