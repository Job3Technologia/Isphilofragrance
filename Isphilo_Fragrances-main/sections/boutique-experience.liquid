{% comment %}
  ISPHILO FRAGRANCE - Boutique Experience Section
{% endcomment %}

<section class="section boutique-experience blurred-bg-section" 
         style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');" 
         role="img" 
         aria-label="Boutique Experience Background">
    <div class="container">
        <div class="boutique-grid">
            <div class="boutique-content reveal-left">
                <p class="section-subtitle">{{ section.settings.subtitle }}</p>
                <h2 class="boutique-title">{{ section.settings.title }}</h2>
                <div class="section-divider" style="margin-left: 0;"></div>
                <div class="boutique-text">
                    {{ section.settings.text }}
                </div>
                {% if section.settings.button_label != blank %}
                    <a href="{{ section.settings.button_url }}" class="btn">{{ section.settings.button_label }}</a>
                {% endif %}
            </div>
            
            <div class="boutique-visual reveal-right">
                <div class="visual-stack">
                    {% if section.settings.image_1 != blank %}
                        <div class="visual-item item-1">
                            <img src="{{ section.settings.image_1 | image_url: width: 800 }}" alt="Boutique Visual 1" loading="lazy">
                        </div>
                    {% endif %}
                    {% if section.settings.image_2 != blank %}
                        <div class="visual-item item-2">
                            <img src="{{ section.settings.image_2 | image_url: width: 600 }}" alt="Boutique Visual 2" loading="lazy">
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .boutique-experience { padding: 120px 0; background-attachment: fixed; }
    .boutique-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 100px; align-items: center; }
    
    .boutique-title { font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 30px; line-height: 1.2; }
    .boutique-text { font-size: 1.1rem; opacity: 0.8; line-height: 1.8; margin-bottom: 40px; }
    .boutique-text p { margin-bottom: 20px; }
    
    .visual-stack { position: relative; height: 500px; }
    .visual-item { position: absolute; border-radius: 20px; overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.2); transition: transform 0.5s ease; }
    .visual-item img { width: 100%; height: 100%; object-fit: cover; }
    
    .item-1 { width: 80%; height: 400px; top: 0; left: 0; z-index: 1; }
    .item-2 { width: 60%; height: 300px; bottom: 0; right: 0; z-index: 2; border: 10px solid var(--pure-white); }
    
    .visual-stack:hover .item-1 { transform: translate(-20px, -20px); }
    .visual-stack:hover .item-2 { transform: translate(20px, 20px); }
    
    @media (max-width: 992px) {
        .boutique-grid { grid-template-columns: 1fr; gap: 60px; }
        .visual-stack { height: 400px; }
        .item-1 { width: 90%; height: 350px; }
        .item-2 { width: 70%; height: 250px; }
    }
</style>

{% schema %}
{
  "name": "Boutique Experience",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The Art of Scent"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Exquisite Craftsmanship from Durban"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Born in the heart of Berea, Isphilo Fragrances is more than a brand—it's a journey into the soul of luxury. Each fragrance is a story of passion, precision, and the vibrant spirit of South Africa.</p>"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Overlay Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore Our Story"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Boutique Experience"
    }
  ]
}
{% endschema %}
