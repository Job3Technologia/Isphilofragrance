{% comment %}
  ISPHILO FRAGRANCE - Hero Section
{% endcomment %}

<section class="hero">
    <div class="hero-slideshow">
        {% for block in section.blocks %}
            <div class="slide {% if forloop.first %}active{% endif %}" 
                 style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('{{ block.settings.image | image_url: width: 2000 }}');" 
                 role="img" 
                 aria-label="{{ block.settings.alt_text }}"></div>
        {% endfor %}
    </div>
    <div class="hero-content">
        <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
        <h1 class="hero-title">
            {{ section.settings.title }}
        </h1>
        <p class="hero-description">
            {{ section.settings.description }}
        </p>
        <div class="btn-group">
            <a href="{{ section.settings.button_1_url }}" class="btn">{{ section.settings.button_1_label }} <i class="fas fa-shopping-bag" style="margin-left: 10px;"></i></a>
            <a href="{{ section.settings.button_2_url }}" class="btn btn-outline" style="border: 1px solid var(--white); color: var(--white);">{{ section.settings.button_2_label }}</a>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Hero Slideshow",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Berea, Durban • South Africa • Est. 2018"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Exquisite Scents<br><span style='color: var(--gold);'>Shipped Worldwide</span>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "From Berea, Durban to every corner of the globe. Experience the luxury of Isphilo Fragance, crafted with passion in KZN and delivered to your doorstep, no matter where you are."
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 Label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_1_url",
      "label": "Button 1 URL"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 Label",
      "default": "Shipping Info"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Button 2 URL"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "default": "Luxury Fragrance Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
