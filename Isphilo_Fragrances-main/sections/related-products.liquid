{% comment %}
  ISPHILO FRAGRANCE - Related Products Section
{% endcomment %}

<section class="section related-products-section" 
         data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}">
    <div class="container">
        {% if recommendations.performed %}
            {% if recommendations.products_count > 0 %}
                <div class="section-header reveal">
                    <p class="section-subtitle">{{ section.settings.subtitle }}</p>
                    <h2 class="section-title">{{ section.settings.title }}</h2>
                    <div class="section-divider"></div>
                </div>

                <div class="product-grid reveal">
                    {% for recommendation in recommendations.products %}
                        {% render 'product-card', product: recommendation %}
                    {% endfor %}
                </div>
            {% endif %}
        {% else %}
            {% comment %} This placeholder allows the section to be dynamically populated via AJAX by Shopify {% endcomment %}
            <div class="product-recommendations-placeholder"></div>
        {% endif %}
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const recommendationsSection = document.querySelector('.related-products-section');
        if (recommendationsSection) {
            const url = recommendationsSection.dataset.url;
            fetch(url)
                .then(response => response.text())
                .then(text => {
                    const html = new DOMParser().parseFromString(text, 'text/html');
                    const recommendations = html.querySelector('.related-products-section');

                    if (recommendations && recommendations.innerHTML.trim().length > 0) {
                        recommendationsSection.innerHTML = recommendations.innerHTML;
                        // Trigger reveal animations for new content
                        if (typeof reveal === 'function') reveal();
                    }
                })
                .catch(e => console.error('Error fetching recommendations:', e));
        }
    });
</script>

{% schema %}
{
  "name": "Related Products",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "You May Also Like"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Complete Your Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Related Products"
    }
  ]
}
{% endschema %}
