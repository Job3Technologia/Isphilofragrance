{% comment %}
  ISPHILO FRAGRANCE - AJAX Cart Drawer Section
{% endcomment %}

<div class="cart-drawer" id="cartDrawer">
    <div class="cart-drawer-overlay" id="closeCartOverlay"></div>
    <div class="cart-drawer-content">
        <div class="cart-drawer-header">
            <h3>Your Selection</h3>
            <div class="close-cart" id="closeCart"><i class="fas fa-times"></i></div>
        </div>

        <div class="cart-drawer-items" id="cartDrawerItems">
            {% comment %} Items will be dynamically loaded via AJAX {% endcomment %}
            <div class="loading-spinner">
                <i class="fas fa-spinner fa-spin"></i>
            </div>
        </div>

        <div class="cart-drawer-footer">
            <div class="cart-drawer-subtotal">
                <span>Subtotal</span>
                <span id="cartDrawerTotal">{{ cart.total_price | money }}</span>
            </div>
            <p class="shipping-note">Shipping and taxes calculated at checkout.</p>
            <div class="cart-drawer-btns">
                <a href="{{ routes.cart_url }}" class="btn btn-outline" style="width: 100%; margin-bottom: 10px;">View Full Cart</a>
                <form action="/checkout" method="post" style="width: 100%;">
                    <button type="submit" name="checkout" class="btn" style="width: 100%;">Checkout <i class="fas fa-lock" style="margin-left: 10px;"></i></button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .cart-drawer { position: fixed; top: 0; right: 0; width: 100%; height: 100%; z-index: 2002; visibility: hidden; transition: all 0.4s ease; }
    .cart-drawer.active { visibility: visible; }
    
    .cart-drawer-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); opacity: 0; transition: opacity 0.4s ease; }
    .cart-drawer.active .cart-drawer-overlay { opacity: 1; }
    
    .cart-drawer-content { position: absolute; top: 0; right: -100%; width: 450px; height: 100%; background: var(--pure-white); box-shadow: -10px 0 50px rgba(0,0,0,0.1); transition: right 0.4s cubic-bezier(0.19, 1, 0.22, 1); display: flex; flex-direction: column; }
    .cart-drawer.active .cart-drawer-content { right: 0; }
    
    .cart-drawer-header { padding: 30px; border-bottom: 1px solid var(--gray-light); display: flex; justify-content: space-between; align-items: center; }
    .cart-drawer-header h3 { font-family: 'Playfair Display', serif; font-size: 1.5rem; }
    .close-cart { cursor: pointer; font-size: 20px; transition: color 0.3s ease; }
    .close-cart:hover { color: var(--primary-red); }
    
    .cart-drawer-items { flex: 1; overflow-y: auto; padding: 30px; }
    .cart-drawer-item { display: grid; grid-template-columns: 80px 1fr 40px; gap: 20px; margin-bottom: 30px; align-items: center; }
    .drawer-item-img img { width: 80px; border-radius: 8px; }
    .drawer-item-info h4 { font-size: 14px; margin-bottom: 5px; }
    .drawer-item-info p { font-size: 12px; opacity: 0.6; margin-bottom: 10px; }
    .drawer-item-price { font-size: 14px; font-weight: 700; color: var(--primary-red); }
    .drawer-item-remove { cursor: pointer; color: var(--gray-light); transition: color 0.3s ease; text-align: right; }
    .drawer-item-remove:hover { color: var(--primary-red); }
    
    .cart-drawer-footer { padding: 30px; background: var(--off-white); border-top: 1px solid var(--gray-light); }
    .cart-drawer-subtotal { display: flex; justify-content: space-between; font-weight: 700; font-size: 1.2rem; margin-bottom: 10px; }
    .shipping-note { font-size: 11px; opacity: 0.5; margin-bottom: 25px; text-align: center; }
    
    .loading-spinner { text-align: center; padding: 50px; font-size: 30px; color: var(--primary-red); }
    
    @media (max-width: 500px) {
        .cart-drawer-content { width: 100%; }
    }
</style>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
