{% comment %}
  ISPHILO FRAGRANCE - Newsletter Section
{% endcomment %}

<section class="section newsletter-section blurred-bg-section" 
         style="background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('{{ section.settings.bg_image | image_url: width: 2000 }}');" 
         role="img" 
         aria-label="Newsletter Subscription Background">
    <div class="container text-center">
        <div class="newsletter-content reveal">
            <p class="section-subtitle" style="color: var(--gold);">{{ section.settings.subtitle }}</p>
            <h2 class="section-title" style="color: var(--pure-white);">{{ section.settings.title }}</h2>
            <div class="section-divider" style="background: var(--gold); margin: 0 auto 30px;"></div>
            <p class="newsletter-text" style="color: var(--pure-white); opacity: 0.8; max-width: 600px; margin: 0 auto 40px; font-size: 1.1rem;">
                {{ section.settings.text }}
            </p>
            
            {% form 'customer', class: 'newsletter-form' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="newsletter-input-group">
                    <input type="email" name="contact[email]" placeholder="Enter your email address..." required 
                           style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; padding: 20px 30px; border-radius: 50px; width: 100%; font-size: 1.1rem; font-family: 'Cormorant Garamond', serif;">
                    <button type="submit" class="btn btn-gold" style="position: absolute; right: 5px; top: 5px; height: calc(100% - 10px); padding: 0 40px; border-radius: 50px; background: var(--gold); color: var(--pure-black); font-weight: 700; text-transform: uppercase; font-size: 11px; letter-spacing: 2px;">
                        Join Now <i class="fas fa-paper-plane" style="margin-left: 10px;"></i>
                    </button>
                </div>
                {% if form.posted_successfully? %}
                    <p class="form-success" style="margin-top: 20px; color: var(--gold);">Welcome to the inner circle. Please check your email!</p>
                {% endif %}
            {% endform %}
        </div>
    </div>
</section>

<style>
    .newsletter-section { padding: 150px 0; background-size: cover; background-position: center; background-attachment: fixed; }
    .newsletter-content { max-width: 800px; margin: 0 auto; }
    .newsletter-input-group { position: relative; max-width: 600px; margin: 0 auto; }
    .newsletter-input-group input:focus { border-color: var(--gold); outline: none; }
    
    @media (max-width: 768px) {
        .newsletter-section { padding: 100px 0; }
        .newsletter-input-group button { position: static; width: 100%; margin-top: 20px; height: 60px; }
        .newsletter-input-group input { border-radius: 12px; }
    }
</style>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The Inner Circle"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Join Our Exclusive Community"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Subscribe to receive early access to new releases, limited-edition boutique collections, and signature fragrance tips."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
