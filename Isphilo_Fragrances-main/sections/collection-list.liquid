{% comment %}
  ISPHILO FRAGRANCE - Collection List Section
{% endcomment %}

<section class="section collection-list-section">
  <div class="container">
    {% if section.settings.title != blank %}
      <div class="section-header reveal">
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
        <h2 class="section-title">{{ section.settings.title }}</h2>
        <div class="section-divider"></div>
      </div>
    {% endif %}

    <div class="collection-grid">
      {% for block in section.blocks %}
        {%- assign collection = collections[block.settings.collection] -%}
        <div class="collection-card reveal" {{ block.shopify_attributes }}>
          <a href="{{ collection.url | default: '#' }}" class="collection-link">
            <div class="collection-image">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ collection.title | escape }}" loading="lazy">
              {% elsif collection.image != blank %}
                <img src="{{ collection.image | image_url: width: 800 }}" alt="{{ collection.title | escape }}" loading="lazy">
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
              <div class="collection-overlay">
                <div class="collection-info">
                  <h3>{{ collection.title | default: 'Collection Title' }}</h3>
                  <span class="collection-count">{{ collection.products_count | default: 0 }} Products</span>
                  <div class="btn btn-outline btn-white">Shop Now</div>
                </div>
              </div>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .collection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    margin-top: 50px;
  }
  .collection-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    height: 450px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    transition: transform 0.5s ease;
  }
  .collection-card:hover {
    transform: translateY(-10px);
  }
  .collection-link {
    display: block;
    height: 100%;
  }
  .collection-image {
    position: relative;
    height: 100%;
  }
  .collection-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }
  .collection-card:hover .collection-image img {
    transform: scale(1.1);
  }
  .collection-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.7));
    display: flex;
    align-items: flex-end;
    padding: 40px;
    transition: background 0.3s ease;
  }
  .collection-info {
    color: white;
    width: 100%;
  }
  .collection-info h3 {
    font-size: 1.8rem;
    margin-bottom: 10px;
    font-family: 'Playfair Display', serif;
  }
  .collection-count {
    display: block;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 20px;
    opacity: 0.8;
  }
  .btn-white {
    border-color: white !important;
    color: white !important;
  }
  .btn-white:hover {
    background: white !important;
    color: black !important;
  }

  @media (max-width: 768px) {
    .collection-card { height: 350px; }
    .collection-overlay { padding: 30px; }
    .collection-info h3 { font-size: 1.5rem; }
  }
</style>

{% schema %}
{
  "name": "Collection List",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The Gallery"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Explore Our Collections",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override Image",
          "info": "Leave blank to use the collection's default image."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
