{% comment %}
  ISPHILO FRAGRANCE - Footer Section
{% endcomment %}

<footer id="footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-brand">
                <a href="{{ routes.root_url }}" class="footer-logo">
                    {% if section.settings.logo != blank %}
                        <img src="{{ section.settings.logo | image_url: width: 100 }}" alt="{{ shop.name }}">
                    {% else %}
                        <div class="logo-text">{{ shop.name }}</div>
                    {% endif %}
                </a>
                <p class="footer-description">
                    {{ section.settings.footer_description }}
                </p>
                <div class="footer-social">
                    {% if settings.social_facebook_link != blank %}<a href="{{ settings.social_facebook_link }}" target="_blank"><i class="fab fa-facebook-f"></i></a>{% endif %}
                    {% if settings.social_instagram_link != blank %}<a href="{{ settings.social_instagram_link }}" target="_blank"><i class="fab fa-instagram"></i></a>{% endif %}
                    {% if settings.social_tiktok_link != blank %}<a href="{{ settings.social_tiktok_link }}" target="_blank"><i class="fab fa-tiktok"></i></a>{% endif %}
                    {% if settings.social_whatsapp_number != blank %}<a href="https://wa.me/{{ settings.social_whatsapp_number }}" target="_blank"><i class="fab fa-whatsapp"></i></a>{% endif %}
                </div>
            </div>

            {% for block in section.blocks %}
                {% if block.type == 'link_list' %}
                <div class="footer-nav">
                    <h4>{{ block.settings.title }}</h4>
                    <ul>
                        {% for link in block.settings.menu.links %}
                            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                        {% endfor %}
                    </ul>
                </div>
                {% endif %}
            {% endfor %}

            <div class="footer-newsletter">
                <h4>{{ section.settings.newsletter_title }}</h4>
                <p>{{ section.settings.newsletter_text }}</p>
                {% form 'customer', class: 'footer-form' %}
                    <div class="footer-input-group">
                        <input type="email" name="contact[email]" placeholder="Email Address" required>
                        <button type="submit">
                            <span>Subscribe</span>
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                {% endform %}
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-copyright">
                &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All Rights Reserved.
            </div>
            <div class="footer-legal">
                {% for link in section.settings.legal_menu.links %}
                    <a href="{{ link.url }}">{{ link.title }}</a>
                {% endfor %}
            </div>
        </div>
    </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "footer_description",
      "label": "Description",
      "default": "Experience the essence of luxury. Crafting premium, long-lasting fragrances in the heart of Durban since 2018."
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title",
      "default": "Newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Join the ISPHILO inner circle for exclusive offers and fragrance launches. Support: info@isphilofragrance.com"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal Menu"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ]
}
{% endschema %}
