{% comment %}
  ISPHILO FRAGRANCE - Header Section
{% endcomment %}

<!-- WHATSAPP FLOAT -->
{% if settings.social_whatsapp_number != blank %}
<a href="https://wa.me/{{ settings.social_whatsapp_number }}" class="whatsapp-float" target="_blank">
    <i class="fab fa-whatsapp"></i>
</a>
{% endif %}

<!-- SMART CAPSULE HEADER -->
<header id="header">
    <div class="nav-container">
        <div style="display: flex; align-items: center;">
            <a href="{{ routes.root_url }}" class="logo-container">
                {% if section.settings.logo != blank %}
                    <img src="{{ section.settings.logo | image_url: width: 200 }}" 
                         alt="{{ shop.name }}" 
                         class="logo-img"
                         width="100"
                         height="auto"
                         loading="eager">
                {% else %}
                    <div class="logo-text">{{ shop.name }}</div>
                {% endif %}
            </a>
        </div>
        
        <ul class="nav-menu">
            {% for link in section.settings.menu.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
        </ul>
        
        <div class="header-actions">
            <div class="header-action-box search-toggle" title="Search">
                <i class="fas fa-search"></i>
            </div>

            <a href="/pages/wishlist" class="header-action-box d-none d-md-flex" title="Wishlist">
                <i class="far fa-heart"></i>
                <span class="wishlist-count-badge wishlist-count">0</span>
            </a>
            
            <a href="{{ routes.cart_url }}" class="cart-pill" aria-label="View Cart">
                <i class="fas fa-shopping-cart"></i>
                <span class="d-none d-md-inline">Cart</span>
                <div class="cart-count-badge cart-count">{{ cart.item_count }}</div>
            </a>
            
            {% if shop.customer_accounts_enabled %}
                <a href="{{ routes.account_url }}" class="header-action-box" style="background: var(--primary-red); color: white;">
                    <i class="fas fa-user"></i>
                </a>
            {% endif %}

            <div class="header-action-box mobile-menu-toggle d-lg-none" role="button">
                <i class="fas fa-bars"></i>
            </div>
        </div>
    </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
